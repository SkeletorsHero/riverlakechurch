\ls8\ilvl0
\f0\b\fs28 \cf2 {\listtext	\uc0\u8226 	}Quit fighting your spiritual battles in the physical realm\
\pard\tx940\tx1440\pardeftab720\li1440\fi-1440\pardirnatural\partightenfactor0
