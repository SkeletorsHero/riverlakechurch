\pard\tx220\tx720\pardeftab720\li720\fi-720\pardirnatural\partightenfactor0
\ls1\ilvl0\cf4 {\listtext	\uc0\u8226 	}This is why we send money overseas and to other ministries\
{\listtext	\uc0\u8226 	}I want to make sure we don\'92t become completely pragmatic but are following the divine.\
{\listtext	\uc0\u8226 	}For many Christians the commitment is equal to the explanation\
\pard\tx940\tx1440\pardeftab720\li1440\fi-1440\pardirnatural\partightenfactor0
\ls1\ilvl1\cf4 {\listtext	\uc0\u8226 	}If we can\'92t see how it will help us we don\'92t do it\
\pard\pardeftab720\pardirnatural\partightenfactor0
