\pard\tx220\tx720\pardeftab720\li720\fi-720\sa150\pardirnatural\partightenfactor0
\ls6\ilvl0\cf0 {\listtext	\uc0\u8226 	}Now this may not seem like a big deal to you but it was back then\'85\
{\listtext	\uc0\u8226 	}David symbolically communicates Saul power and authority have been cut off this day.  \
\pard\pardeftab720\sa150\pardirnatural\qc\partightenfactor0
