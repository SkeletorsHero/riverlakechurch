\pard\tx220\tx720\pardeftab720\li720\fi-720\pardirnatural\partightenfactor0
\ls2\ilvl0
\f1\b0\fs24 \cf0 {\listtext	\uc0\u8226 	}It\'92s one thing to talk about right and wrong\'85everyone does that.\
{\listtext	\uc0\u8226 	}It\'92s one thing to talk about God in an abstract way\'85lots of people believe in God.\
{\listtext	\uc0\u8226 	}It\'92s even ok to talk about this force or small voice in your head that doesn\'92t seem to come from you or is in you but you seem to have a conversation with\'85because you can just chalk it up to you\'92re crazy and move on.\
{\listtext	\uc0\u8226 	}But it\'92s a whole different issue when you start talking about having a relationship with God\'92s spirit and talking to Him.\
\pard\pardeftab720\pardirnatural\partightenfactor0
\cf0 \
\pard\pardeftab720\pardirnatural\partightenfactor0

