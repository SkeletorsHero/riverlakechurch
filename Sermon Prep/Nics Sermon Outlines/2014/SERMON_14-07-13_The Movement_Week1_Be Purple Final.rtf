\pard\tx220\tx720\pardeftab720\li720\fi-720\pardirnatural\partightenfactor0
\ls10\ilvl0
\fs28 \cf0 {\listtext	\uc0\u8226 	}This is a Purple Church\
\pard\tx940\tx1440\pardeftab720\li1440\fi-1440\pardirnatural\partightenfactor0
\ls10\ilvl1
\f1\b0\fs24 \cf0 {\listtext	\uc0\u8226 	}We are different and on purpose!\
{\listtext	\uc0\u8226 	}As a church this means we will be us\'85we will embrace our unique calling to be purple as a church.\
\pard\pardeftab720\pardirnatural\partightenfactor0
