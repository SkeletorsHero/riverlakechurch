\cf2 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa150\pardirnatural\partightenfactor0
\ls4\ilvl0\cf3 {\listtext	\uc0\u8226 	}We\'92re a church that has consistently dug ditches and simply allowed God to fill them up.\
{\listtext	\uc0\u8226 	}We setup chairs every single week\'85and guess what?  God brings people and fills them!\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa150\pardirnatural\partightenfactor0
\ls4\ilvl0
