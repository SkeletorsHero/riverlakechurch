\f4\b\fs28 \cf3 Corporately \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa150\pardirnatural\partightenfactor0
\ls10\ilvl0
\f3\b0\fs24 \cf3 {\listtext	\uc0\u8226 	}We\'92re going to keep digging ditches and trust God has something great for us\
