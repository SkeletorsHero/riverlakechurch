\f3\b\fs18 \cf3 \super 9\'a0
\f5\b0\fs24 \nosupersub After Jacob returned from Paddan Aram,
\fs15 \super [c]
\fs24 \nosupersub \'a0God appeared to him again and blessed him.\'a0
\f3\b\fs18 \super 10\'a0
