\pard\tx220\tx720\pardeftab720\li720\fi-720\pardirnatural\partightenfactor0
\ls3\ilvl0
\f1\b0\fs24 \cf0 {\listtext	\uc0\u8226 	}We want to blame in on our circumstances but we can\'92t\
{\listtext	\uc0\u8226 	}We want to blame it on luck, but that isn\'92t even a real thing\
{\listtext	\uc0\u8226 	}We want to blame it on lack of time but everyone has the same amount of time\
