\ls3\ilvl1
\f2\b0 \cf0 {\listtext	\uc0\u8226 	}Forgive someone else\
{\listtext	\uc0\u8226 	}Give money to His mission\
{\listtext	\uc0\u8226 	}Love your enemy \
\pard\pardeftab720\pardirnatural\partightenfactor0
