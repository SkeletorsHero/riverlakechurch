\outl0\strokewidth0 \strokec2 So today we\'92re\'a0taking a second look\'85and today I want you to know\'85I\'92m going to push you\'85hard!
\f1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls1\ilvl0
\f2\fs28 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 There is a really good chance I\'92m going to offend someone today\'85I want you ready and I want you to know my heart\'85I don\'92t want you to waste your life!
\f1\fs24 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls1\ilvl0
