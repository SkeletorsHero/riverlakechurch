\ls3\ilvl1\cf4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u9702 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec4 If you are walking with God you\'a0don\'92t\'a0have a to worry about God\cf2 \strokec2 \uc0\u8232 \
