\outl0\strokewidth0 \strokec2 I\'92m glad you are good with God\'85now get on board with His mission.\uc0\u8232 \
\ls4\ilvl0\kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 This is why churches die.\uc0\u8232 \
