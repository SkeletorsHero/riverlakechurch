\
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls2\ilvl0\cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 If you have a Bible you can turn to Ephesians chapter 3 - we're going to start there and then flip into the Old Testament.\uc0\u8232 \
\pard\pardeftab720\partightenfactor0
