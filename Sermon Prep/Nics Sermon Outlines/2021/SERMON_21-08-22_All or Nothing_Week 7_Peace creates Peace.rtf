\outl0\strokewidth0 \strokec3 Peace is to unify God's people under God's grace to fulfill God's plan.\cf2 \strokec2 \uc0\u8232 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
