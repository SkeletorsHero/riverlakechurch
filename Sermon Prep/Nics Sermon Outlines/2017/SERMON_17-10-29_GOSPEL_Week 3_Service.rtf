\pard\tx220\tx720\pardeftab720\li720\fi-720\sl576\partightenfactor0
\ls8\ilvl0
\f2\fs32 \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
